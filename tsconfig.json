{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "renderer/js",
    "rootDir": "renderer/ts",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false,
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": ["renderer/ts/**/*.ts"],
  "exclude": ["node_modules", "_deprecated"]
}
